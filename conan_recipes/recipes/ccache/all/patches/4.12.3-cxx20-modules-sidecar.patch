@@ -0,0 +1,361 @@
+# Test C++20 named modules with sidecar-based cache coherence.
+#
+# Producer compiles emit a BMI/PCM specified via -fmodule-output=<path>.
+# ccache treats the PCM as a tracked secondary cached output and writes
+# a "<pcm>.ccache-meta" sidecar containing the producer's result_key.
+#
+# Consumers reference modules via -fmodule-file=[<name>=]<path>. Instead
+# of hashing PCM bytes (which embed absolute paths and so over-invalidate
+# whenever the build path or Conan dependency paths drift), ccache reads
+# the sidecar and folds its recorded result_key into the consumer hash.
+# If the sidecar is missing or its (size, mtime) snapshot disagrees with
+# the current PCM, the consumer fails closed (could_not_use_module_sidecar).
+#
+# Scope: -fmodule-file= consumer hashing and -fmodule-output= producer
+# caching. Out of scope: -fprebuilt-module-path= directory lookup,
+# --precompile (produces PCM with no .o; not the CMake/clang flow), MSVC
+# /reference and /ifcOutput, and GCC's implicit .gcm caching.
+
+SUITE_cxx20_modules_PROBE() {
+    if ! $COMPILER_TYPE_CLANG; then
+        echo "C++20 named modules require Clang"
+        return
+    fi
+
+    cat <<EOF >probe_mod.cppm
+export module probe;
+export int probe_value = 1;
+EOF
+
+    # Use the same compile shape we test below: -x c++-module with both
+    # .o and .pcm outputs in one invocation. This is what CMake+ninja's
+    # clang-scan-deps flow generates for cppm sources.
+    if ! $COMPILER -std=c++20 -x c++-module -fmodule-output=probe_mod.pcm \
+            -c probe_mod.cppm -o probe_mod.cppm.o 2>/dev/null \
+        || ! [ -f probe_mod.pcm ]; then
+        echo "compiler does not support -fmodule-output= producer flow"
+        rm -f probe_mod.cppm probe_mod.pcm probe_mod.cppm.o
+        return
+    fi
+
+    cat <<EOF >probe_consumer.cpp
+import probe;
+int main() { return probe_value; }
+EOF
+    if ! $COMPILER -std=c++20 -fmodule-file=probe=probe_mod.pcm \
+            -c probe_consumer.cpp -o probe_consumer.o 2>/dev/null; then
+        echo "compiler does not support -fmodule-file=name=file syntax"
+    fi
+
+    rm -f probe_mod.cppm probe_mod.pcm probe_mod.cppm.o
+    rm -f probe_consumer.cpp probe_consumer.o
+}
+
+SUITE_cxx20_modules_SETUP() {
+    unset CCACHE_NODIRECT
+
+    cat <<EOF >mod.cppm
+export module mod;
+export struct Base {
+    int x = 42;
+};
+EOF
+
+    cat <<EOF >consumer.cpp
+import mod;
+int get_x() {
+    Base b;
+    return b.x;
+}
+EOF
+}
+
+# Build a module producer through ccache. After this, mod.pcm and
+# mod.pcm.ccache-meta both exist on disk.
+ccache_build_producer() {
+    local pcm_out="$1"; shift
+    $CCACHE_COMPILE -std=c++20 -x c++-module \
+        -fmodule-output="$pcm_out" \
+        -c mod.cppm -o mod.cppm.o "$@"
+}
+
+SUITE_cxx20_modules() {
+    # -------------------------------------------------------------------------
+    TEST "producer caches .pcm and writes sidecar"
+
+    ccache_build_producer mod.pcm
+    expect_stat direct_cache_miss 1
+    expect_exists mod.pcm
+    expect_exists mod.pcm.ccache-meta
+
+    # Sidecar must list result_key, pcm_size, pcm_mtime_ns.
+    grep -q '^result_key=' mod.pcm.ccache-meta \
+        || test_failed "sidecar missing result_key line"
+    grep -q '^pcm_size=' mod.pcm.ccache-meta \
+        || test_failed "sidecar missing pcm_size line"
+    grep -q '^pcm_mtime_ns=' mod.pcm.ccache-meta \
+        || test_failed "sidecar missing pcm_mtime_ns line"
+
+    # Wipe outputs and rebuild — must be a producer cache hit, restoring
+    # both .o and .pcm from cache, then re-synthesising the sidecar.
+    rm -f mod.cppm.o mod.pcm mod.pcm.ccache-meta
+
+    ccache_build_producer mod.pcm
+    expect_stat direct_cache_hit 1
+    expect_stat direct_cache_miss 1
+    expect_exists mod.cppm.o
+    expect_exists mod.pcm
+    expect_exists mod.pcm.ccache-meta
+
+    # -------------------------------------------------------------------------
+    TEST "consumer hits when sidecar is valid"
+
+    ccache_build_producer mod.pcm
+    expect_stat direct_cache_miss 1
+
+    # First consumer compile: cache miss (cold).
+    $CCACHE_COMPILE -std=c++20 -fmodule-file=mod=mod.pcm \
+        -c consumer.cpp -o consumer.o
+    expect_stat direct_cache_hit 0
+    expect_stat direct_cache_miss 2
+    expect_stat could_not_use_module_sidecar 0
+
+    # Second consumer compile: cache hit, sidecar consulted, no PCM bytes hashed.
+    $CCACHE_COMPILE -std=c++20 -fmodule-file=mod=mod.pcm \
+        -c consumer.cpp -o consumer.o
+    expect_stat direct_cache_hit 1
+    expect_stat direct_cache_miss 2
+    expect_stat could_not_use_module_sidecar 0
+
+    # -------------------------------------------------------------------------
+    TEST "consumer hit survives PCM byte differences when result_key is unchanged"
+
+    # Establish baseline: producer miss + consumer miss, then consumer hit.
+    ccache_build_producer mod.pcm
+    expect_stat direct_cache_miss 1
+
+    $CCACHE_COMPILE -std=c++20 -fmodule-file=mod=mod.pcm \
+        -c consumer.cpp -o consumer.o
+    expect_stat direct_cache_miss 2
+
+    $CCACHE_COMPILE -std=c++20 -fmodule-file=mod=mod.pcm \
+        -c consumer.cpp -o consumer.o
+    expect_stat direct_cache_hit 1
+
+    # Simulate PCM byte drift WITHOUT a logical change (e.g. Conan path
+    # drift in CI): replace PCM with a byte-different copy, and rewrite
+    # only the (size, mtime) fields in the sidecar so it still matches
+    # the on-disk PCM. result_key stays the same — that's the invariant
+    # we hash on the consumer side.
+    printf '   ' >> mod.pcm
+    new_size=$(stat -c%s mod.pcm 2>/dev/null || stat -f%z mod.pcm)
+    new_mtime_ns=$(python3 -c "import os; print(os.stat('mod.pcm').st_mtime_ns)")
+
+    awk -v sz="$new_size" -v mt="$new_mtime_ns" '
+        /^pcm_size=/    { print "pcm_size=" sz; next }
+        /^pcm_mtime_ns=/{ print "pcm_mtime_ns=" mt; next }
+        { print }
+    ' mod.pcm.ccache-meta > mod.pcm.ccache-meta.new
+    mv mod.pcm.ccache-meta.new mod.pcm.ccache-meta
+
+    $CCACHE_COMPILE -std=c++20 -fmodule-file=mod=mod.pcm \
+        -c consumer.cpp -o consumer.o
+    expect_stat direct_cache_hit 2
+    expect_stat could_not_use_module_sidecar 0
+
+    # -------------------------------------------------------------------------
+    TEST "consumer fails closed when sidecar is absent"
+
+    # Build PCM directly (no ccache) — no sidecar produced.
+    $COMPILER -std=c++20 -x c++-module -fmodule-output=mod.pcm \
+        -c mod.cppm -o mod.cppm.o
+    rm -f mod.pcm.ccache-meta
+
+    $CCACHE_COMPILE -std=c++20 -fmodule-file=mod=mod.pcm \
+        -c consumer.cpp -o consumer.o
+    expect_stat could_not_use_module_sidecar 1
+    expect_stat direct_cache_hit 0
+
+    # -------------------------------------------------------------------------
+    TEST "consumer fails closed when sidecar is stale (size mismatch)"
+
+    ccache_build_producer mod.pcm
+    expect_stat direct_cache_miss 1
+
+    # Consumer cold compile populates the cache (another miss).
+    $CCACHE_COMPILE -std=c++20 -fmodule-file=mod=mod.pcm \
+        -c consumer.cpp -o consumer.o
+    expect_stat direct_cache_miss 2
+    expect_stat could_not_use_module_sidecar 0
+
+    # Mutate the PCM directly (someone bypasses ccache to rebuild it).
+    # The sidecar's recorded (size, mtime) now disagrees with the
+    # on-disk PCM, so the consumer must fail closed rather than risk a
+    # stale .o.
+    printf 'extra' >> mod.pcm
+
+    $CCACHE_COMPILE -std=c++20 -fmodule-file=mod=mod.pcm \
+        -c consumer.cpp -o consumer.o
+    expect_stat could_not_use_module_sidecar 1
+    expect_stat direct_cache_hit 0
+
+    # -------------------------------------------------------------------------
+    TEST "logical change to PCM source produces new result_key and consumer miss"
+
+    ccache_build_producer mod.pcm                        # producer miss 1
+    $CCACHE_COMPILE -std=c++20 -fmodule-file=mod=mod.pcm \
+        -c consumer.cpp -o consumer.o                    # consumer miss 2
+    $CCACHE_COMPILE -std=c++20 -fmodule-file=mod=mod.pcm \
+        -c consumer.cpp -o consumer.o                    # consumer hit 1
+    expect_stat direct_cache_hit 1
+    expect_stat direct_cache_miss 2
+
+    # Add a field — struct layout shifts; consumer.o compiled against the
+    # old PCM would have wrong offsets, so this MUST miss.
+    cat <<EOF >mod.cppm
+export module mod;
+export struct Base {
+    int x = 42;
+    int y = 99;
+};
+EOF
+    ccache_build_producer mod.pcm                        # producer miss 3
+
+    $CCACHE_COMPILE -std=c++20 -fmodule-file=mod=mod.pcm \
+        -c consumer.cpp -o consumer.o                    # consumer miss 4
+    expect_stat direct_cache_hit 1
+    expect_stat direct_cache_miss 4
+
+    # -------------------------------------------------------------------------
+    TEST "consumer fails closed when sidecar is stale (mtime mismatch)"
+
+    # Sidecar staleness has two failure modes: size or mtime. Test mtime.
+    ccache_build_producer mod.pcm
+    $CCACHE_COMPILE -std=c++20 -fmodule-file=mod=mod.pcm \
+        -c consumer.cpp -o consumer.o
+    expect_stat direct_cache_miss 2
+    expect_stat could_not_use_module_sidecar 0
+
+    # Touch the PCM (size identical, mtime shifts forward).
+    sleep 1
+    touch mod.pcm
+
+    $CCACHE_COMPILE -std=c++20 -fmodule-file=mod=mod.pcm \
+        -c consumer.cpp -o consumer.o
+    expect_stat could_not_use_module_sidecar 1
+    expect_stat direct_cache_hit 0
+
+    # -------------------------------------------------------------------------
+    TEST "modmap response file (@file) with quoted -fmodule-output= path"
+
+    # CMake/ninja invokes module producers as:
+    #   clang++ ... @<modmap_file> -o <obj> -c <cppm>
+    # where <modmap_file> contains "-x c++-module" and "-fmodule-output=...".
+    # ccache must expand the @-file so it sees -fmodule-output= and treats
+    # the compile as a module producer.
+    #
+    # CMake's planner-style modmaps quote the output path
+    # ("-fmodule-output="src/.../foo.pcm""), and ccache must strip the
+    # surrounding double-quotes so the recorded args_info.output_pcm
+    # matches the path the compiler actually writes to.
+    cat <<EOF >mod.modmap
+-x c++-module
+-fmodule-output="mod.pcm"
+EOF
+    $CCACHE_COMPILE -std=c++20 @mod.modmap -c mod.cppm -o mod.cppm.o
+    expect_stat direct_cache_miss 1
+    expect_exists mod.pcm
+    expect_exists mod.pcm.ccache-meta
+
+    # Identical re-invocation via @-file: must hit, .pcm restored.
+    rm -f mod.cppm.o mod.pcm mod.pcm.ccache-meta
+    $CCACHE_COMPILE -std=c++20 @mod.modmap -c mod.cppm -o mod.cppm.o
+    expect_stat direct_cache_hit 1
+    expect_exists mod.cppm.o
+    expect_exists mod.pcm
+    expect_exists mod.pcm.ccache-meta
+
+    # -------------------------------------------------------------------------
+    TEST "producer-that-also-consumes: transitive change propagates"
+
+    # Real codebases have module producers that themselves import other
+    # modules (e.g. memgraph property_value.cppm imports memgraph.utils.fnv).
+    # Their modmap contains BOTH -fmodule-output= and -fmodule-file=.
+    # When the imported module's source changes, the importing producer's
+    # hash must also change so its own consumers miss.
+
+    # Lower-level module "leaf".
+    cat <<EOF >leaf.cppm
+export module leaf;
+export int leaf_value() { return 1; }
+EOF
+
+    # Higher-level module "top" that imports leaf and re-exposes a value
+    # derived from it.
+    cat <<EOF >top.cppm
+export module top;
+import leaf;
+export int top_value() { return leaf_value() + 10; }
+EOF
+
+    cat <<EOF >top_consumer.cpp
+import top;
+int main_top() { return top_value(); }
+EOF
+
+    # Build leaf, then top (consuming leaf via -fmodule-file=), then a
+    # consumer of top. Counts as we go:
+    #   leaf producer compile          -> direct_cache_miss = 1
+    #   top producer compile           -> direct_cache_miss = 2
+    #   top_consumer compile (cold)    -> direct_cache_miss = 3
+    #   top_consumer compile (replay)  -> direct_cache_hit  = 1
+    $CCACHE_COMPILE -std=c++20 -x c++-module \
+        -fmodule-output=leaf.pcm \
+        -c leaf.cppm -o leaf.cppm.o
+    expect_exists leaf.pcm.ccache-meta
+
+    $CCACHE_COMPILE -std=c++20 -x c++-module \
+        -fmodule-output=top.pcm \
+        -fmodule-file=leaf=leaf.pcm \
+        -c top.cppm -o top.cppm.o
+    expect_exists top.pcm.ccache-meta
+
+    $CCACHE_COMPILE -std=c++20 \
+        -fmodule-file=leaf=leaf.pcm -fmodule-file=top=top.pcm \
+        -c top_consumer.cpp -o top_consumer.o
+
+    $CCACHE_COMPILE -std=c++20 \
+        -fmodule-file=leaf=leaf.pcm -fmodule-file=top=top.pcm \
+        -c top_consumer.cpp -o top_consumer.o
+    expect_stat direct_cache_hit 1
+    expect_stat direct_cache_miss 3
+
+    # Now mutate leaf's source. This must propagate transitively:
+    #   leaf source change -> leaf.pcm rebuilt with new result_key
+    #     -> leaf.pcm.ccache-meta result_key changes
+    #     -> top's compile (which imports leaf via -fmodule-file=) hashes
+    #        leaf's new result_key, so top's own result_key changes
+    #     -> top.pcm.ccache-meta result_key changes
+    #     -> top_consumer's hash changes -> miss (not hit).
+    cat <<EOF >leaf.cppm
+export module leaf;
+export int leaf_value() { return 999; }   // logical change
+EOF
+
+    $CCACHE_COMPILE -std=c++20 -x c++-module \
+        -fmodule-output=leaf.pcm \
+        -c leaf.cppm -o leaf.cppm.o                          # leaf miss   -> 4
+    $CCACHE_COMPILE -std=c++20 -x c++-module \
+        -fmodule-output=top.pcm \
+        -fmodule-file=leaf=leaf.pcm \
+        -c top.cppm -o top.cppm.o                            # top miss    -> 5
+    $CCACHE_COMPILE -std=c++20 \
+        -fmodule-file=leaf=leaf.pcm -fmodule-file=top=top.pcm \
+        -c top_consumer.cpp -o top_consumer.o                # consumer miss -> 6
+
+    # Hit count must NOT advance — the transitive change invalidated the
+    # consumer's cache key. If the .pcm bytes had been hashed instead of
+    # the result_key chain, the consumer might have hit on a stale .o.
+    expect_stat direct_cache_hit 1
+    expect_stat direct_cache_miss 6
+}
