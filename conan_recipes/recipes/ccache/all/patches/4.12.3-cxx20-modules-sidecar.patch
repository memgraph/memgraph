diff --git a/src/ccache/module_sidecar.cpp b/src/ccache/module_sidecar.cpp
new file mode 100644
index 00000000..6a79ea5c
--- /dev/null
+++ b/src/ccache/module_sidecar.cpp
@@ -0,0 +1,165 @@
+// Copyright (C) 2026 Joel Rosdahl and other contributors
+//
+// See doc/authors.adoc for a complete list of contributors.
+//
+// This program is free software; you can redistribute it and/or modify it
+// under the terms of the GNU General Public License as published by the Free
+// Software Foundation; either version 3 of the License, or (at your option)
+// any later version.
+
+#include "module_sidecar.hpp"
+
+#include <ccache/util/direntry.hpp>
+#include <ccache/util/file.hpp>
+#include <ccache/util/format.hpp>
+#include <ccache/util/logging.hpp>
+#include <ccache/util/string.hpp>
+#include <ccache/util/time.hpp>
+
+#include <charconv>
+#include <string_view>
+
+namespace fs = std::filesystem;
+
+namespace {
+
+constexpr std::string_view k_sidecar_suffix = ".ccache-meta";
+
+// Decode a lowercase hex string of length 2*N into the digest. Returns false
+// on any non-hex character or wrong length.
+bool
+parse_hex_digest(std::string_view hex, Hash::Digest& out)
+{
+  if (hex.size() != 2 * out.size()) {
+    return false;
+  }
+  for (size_t i = 0; i < out.size(); ++i) {
+    uint8_t byte = 0;
+    auto [_, ec] =
+      std::from_chars(hex.data() + 2 * i, hex.data() + 2 * i + 2, byte, 16);
+    if (ec != std::errc{}) {
+      return false;
+    }
+    out[i] = byte;
+  }
+  return true;
+}
+
+std::string
+format_hex_digest(const Hash::Digest& d)
+{
+  std::string out;
+  out.reserve(2 * d.size());
+  static constexpr char k_hex[] = "0123456789abcdef";
+  for (uint8_t b : d) {
+    out.push_back(k_hex[b >> 4]);
+    out.push_back(k_hex[b & 0xf]);
+  }
+  return out;
+}
+
+} // namespace
+
+fs::path
+ModuleSidecar::sidecar_path_for(const fs::path& pcm_path)
+{
+  fs::path p = pcm_path;
+  p += k_sidecar_suffix;
+  return p;
+}
+
+std::optional<ModuleSidecar>
+ModuleSidecar::read_for(const fs::path& pcm_path)
+{
+  const auto path = sidecar_path_for(pcm_path);
+  auto data = util::read_file<std::string>(path);
+  if (!data) {
+    return std::nullopt;
+  }
+
+  ModuleSidecar out;
+  bool saw_key = false;
+  bool saw_size = false;
+  bool saw_mtime = false;
+
+  for (auto line : util::split_into_views(*data, "\n")) {
+    if (line.empty()) {
+      continue;
+    }
+    auto eq = line.find('=');
+    if (eq == std::string_view::npos) {
+      continue;
+    }
+    auto key = line.substr(0, eq);
+    auto val = line.substr(eq + 1);
+
+    if (key == "result_key") {
+      if (!parse_hex_digest(val, out.result_key)) {
+        LOG("Module sidecar at {} has malformed result_key", path);
+        return std::nullopt;
+      }
+      saw_key = true;
+    } else if (key == "pcm_size") {
+      auto [_, ec] =
+        std::from_chars(val.data(), val.data() + val.size(), out.pcm_size);
+      if (ec != std::errc{}) {
+        LOG("Module sidecar at {} has malformed pcm_size", path);
+        return std::nullopt;
+      }
+      saw_size = true;
+    } else if (key == "pcm_mtime_ns") {
+      auto [_, ec] =
+        std::from_chars(val.data(), val.data() + val.size(), out.pcm_mtime_ns);
+      if (ec != std::errc{}) {
+        LOG("Module sidecar at {} has malformed pcm_mtime_ns", path);
+        return std::nullopt;
+      }
+      saw_mtime = true;
+    }
+    // Unknown keys ignored for forward compatibility.
+  }
+
+  if (!saw_key || !saw_size || !saw_mtime) {
+    LOG("Module sidecar at {} is missing required keys", path);
+    return std::nullopt;
+  }
+  return out;
+}
+
+bool
+ModuleSidecar::write_for(const fs::path& pcm_path,
+                         const Hash::Digest& result_key)
+{
+  util::DirEntry pcm(pcm_path);
+  if (!pcm.is_regular_file()) {
+    LOG("Cannot write module sidecar; pcm missing or not a regular file: {}",
+        pcm_path);
+    return false;
+  }
+
+  const auto body = fmt::format("result_key={}\n"
+                                "pcm_size={}\n"
+                                "pcm_mtime_ns={}\n",
+                                format_hex_digest(result_key),
+                                pcm.size(),
+                                pcm.mtime().nsec());
+
+  const auto path = sidecar_path_for(pcm_path);
+  auto r = util::write_file(path, body, util::WriteFileMode::unlink);
+  if (!r) {
+    LOG("Failed to write module sidecar {}: {}", path, r.error());
+    return false;
+  }
+  return true;
+}
+
+bool
+ModuleSidecar::matches_pcm(const fs::path& pcm_path) const
+{
+  util::DirEntry pcm(pcm_path);
+  if (!pcm.is_regular_file()) {
+    return false;
+  }
+  return pcm.size() == pcm_size
+         && pcm.mtime().nsec() == pcm_mtime_ns;
+}
diff --git a/src/ccache/module_sidecar.hpp b/src/ccache/module_sidecar.hpp
new file mode 100644
index 00000000..e9e82961
--- /dev/null
+++ b/src/ccache/module_sidecar.hpp
@@ -0,0 +1,55 @@
+// Copyright (C) 2026 Joel Rosdahl and other contributors
+//
+// See doc/authors.adoc for a complete list of contributors.
+//
+// This program is free software; you can redistribute it and/or modify it
+// under the terms of the GNU General Public License as published by the Free
+// Software Foundation; either version 3 of the License, or (at your option)
+// any later version.
+
+#pragma once
+
+#include <ccache/hash.hpp>
+
+#include <cstdint>
+#include <filesystem>
+#include <optional>
+
+// Sidecar file written next to a C++20 module BMI/PCM as
+// "<pcm_path>.ccache-meta". Encodes the producer compilation's result_key
+// together with stat metadata that lets a consumer detect a stale sidecar
+// without re-hashing PCM bytes.
+//
+// File format (text, key=value, one entry per line, LF terminator):
+//
+//   result_key=<lowercase hex of digest>
+//   pcm_size=<bytes>
+//   pcm_mtime_ns=<nanoseconds since unix epoch>
+//
+// Future extensions append new keys. Unknown keys are ignored on read.
+class ModuleSidecar
+{
+public:
+  Hash::Digest result_key{};
+  uint64_t pcm_size = 0;
+  int64_t pcm_mtime_ns = 0;
+
+  // Read and parse the sidecar at "<pcm_path>.ccache-meta". Returns
+  // std::nullopt if the file is missing or malformed.
+  static std::optional<ModuleSidecar>
+  read_for(const std::filesystem::path& pcm_path);
+
+  // Write a sidecar describing the just-emitted PCM at pcm_path. Synthesises
+  // (pcm_size, pcm_mtime_ns) from the current stat of pcm_path. Returns
+  // false if the PCM does not exist or the write failed (a missing sidecar
+  // is non-fatal but means future consumers will fail closed).
+  static bool write_for(const std::filesystem::path& pcm_path,
+                        const Hash::Digest& result_key);
+
+  // Whether this sidecar's recorded (size, mtime) match the current stat
+  // of pcm_path. Mismatch indicates the PCM was rewritten outside ccache.
+  bool matches_pcm(const std::filesystem::path& pcm_path) const;
+
+  // Path of the sidecar associated with pcm_path.
+  static std::filesystem::path sidecar_path_for(const std::filesystem::path& pcm_path);
+};
