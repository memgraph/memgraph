+            "refusing to cache (fail-closed)",
+            pcm_path);
+        return tl::unexpected(Statistic::could_not_use_module_sidecar);
+      }
+      hash.hash_delimiter("module_file");
+      hash.hash(sidecar->result_key);
+      return {};
+    }
+  }
+
   if (util::starts_with(args[i], "-fplugin=")) {
     DirEntry dir_entry(&args[i][9], DirEntry::LogOnError::yes);
     if (dir_entry.is_regular_file()) {
@@ -2523,6 +2584,13 @@ from_cache(Context& ctx, FromCacheCallMode mode, const Hash::Digest& result_key)
