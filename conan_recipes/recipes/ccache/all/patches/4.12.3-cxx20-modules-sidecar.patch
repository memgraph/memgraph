@@ -2154,6 +2173,48 @@ hash_argument(const Context& ctx,
     return {};
   }
 
+  // C++20 named modules: -fmodule-file=[<name>=]<file>
+  //
+  // The PCM is a content-bearing input that affects emitted code (struct
+  // layouts, template instantiations). However the PCM bytes vary with
+  // absolute paths embedded inside the BMI, which makes byte-content
+  // hashing over-invalidate (the same logical inputs at a different build
+  // path yields different bytes). Instead of hashing PCM bytes, fold in
+  // the producer's result_key as recorded in the sidecar
+  // "<pcm>.ccache-meta", validating its (size, mtime) snapshot against
+  // the current PCM stat. This keys the consumer to the *logical* inputs
+  // of the producer rather than the byte-level result.
+  //
+  // Fail-closed: if the sidecar is absent or stale, refuse to cache this
+  // compile. A stale sidecar would otherwise risk returning an .o that
+  // does not match the current PCM (the original ODR/struct-layout bug).
+  if (util::starts_with(args[i], "-fmodule-file=")) {
+    std::string_view val = std::string_view(args[i]).substr(14);
+    // -fmodule-file=<file> or -fmodule-file=<name>=<file>
+    auto eq_pos = val.find('=');
