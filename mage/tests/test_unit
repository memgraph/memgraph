#!/usr/bin/env python3

import multiprocessing as mp
import os
import subprocess

WORK_DIRECTORY = os.getcwd()
REPO_ROOT = os.path.dirname(WORK_DIRECTORY)
PY_DIRECTORY = f"{WORK_DIRECTORY}/python"

#################################################
#            Unit Test C++ modules              #
#################################################
# MAGE is built as part of the root CMake tree (./build.sh --mage on); its unit
# tests are registered with the mage__ prefix in the root build directory.
BUILD_DIRECTORY = f"{REPO_ROOT}/build"
if not os.path.exists(BUILD_DIRECTORY):
    print("No build directory! Build with `./build.sh --mage on` from the repo root.")
    exit(1)

# Run ctest
os.chdir(BUILD_DIRECTORY)
core_count = mp.cpu_count()
subprocess.run(["ctest", "-R", "mage__", f"-j{core_count}"])

#################################################
#           Unit Test Python modules            #
#################################################

os.environ["PYTHONPATH"] = PY_DIRECTORY
os.chdir(PY_DIRECTORY)
subprocess.run(["pytest", "."])
