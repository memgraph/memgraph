#!/bin/sh
set -e

case "$1" in
    configure)
        # install requirements as user memgraph
        CUDA=@CUDA@
        ARCH=@ARCH@
        su - memgraph -c "/usr/lib/memgraph/install_python_requirements.sh --deb-package --cuda $CUDA --arch $ARCH"
        systemctl restart memgraph.service
    ;;
esac

exit 0
